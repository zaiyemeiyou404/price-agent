{
  "info": {
    "_postman_id": "e69b11d8-68f9-4f0c-8d5d-6cc7ee8d9b11",
    "name": "Price Agent API",
    "description": "Price Agent 联调集合（health/capabilities/platforms/compare）。",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Health",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{base_url}}/health",
          "host": [
            "{{base_url}}"
          ],
          "path": [
            "health"
          ]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('status is 200', function () {",
              "  pm.response.to.have.status(200);",
              "});"
            ]
          }
        }
      ]
    },
    {
      "name": "Capabilities",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{base_url}}/api/v1/capabilities",
          "host": [
            "{{base_url}}"
          ],
          "path": [
            "api",
            "v1",
            "capabilities"
          ]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('status is 200', function () {",
              "  pm.response.to.have.status(200);",
              "});",
              "var json = pm.response.json();",
              "pm.test('has mode', function () {",
              "  pm.expect(json).to.have.property('mode');",
              "});",
              "pm.test('has enabled_platforms', function () {",
              "  pm.expect(json).to.have.property('enabled_platforms');",
              "});"
            ]
          }
        }
      ]
    },
    {
      "name": "Platforms (Legacy)",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{base_url}}/api/v1/platforms",
          "host": [
            "{{base_url}}"
          ],
          "path": [
            "api",
            "v1",
            "platforms"
          ]
        }
      }
    },
    {
      "name": "Compare - Shopping (Taobao)",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json",
            "type": "text"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"query\": \"{{query}}\",\n  \"type\": \"shopping\",\n  \"platforms\": [\"taobao\"]\n}"
        },
        "url": {
          "raw": "{{base_url}}/api/v1/compare",
          "host": [
            "{{base_url}}"
          ],
          "path": [
            "api",
            "v1",
            "compare"
          ]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('status is 200', function () {",
              "  pm.response.to.have.status(200);",
              "});",
              "var json = pm.response.json();",
              "pm.test('has products array', function () {",
              "  pm.expect(json).to.have.property('products');",
              "  pm.expect(json.products).to.be.an('array');",
              "});"
            ]
          }
        }
      ]
    },
    {
      "name": "Compare - Shopping (Auto Platforms)",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json",
            "type": "text"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"query\": \"{{query}}\",\n  \"type\": \"shopping\"\n}"
        },
        "url": {
          "raw": "{{base_url}}/api/v1/compare",
          "host": [
            "{{base_url}}"
          ],
          "path": [
            "api",
            "v1",
            "compare"
          ]
        }
      }
    }
  ],
  "variable": [
    {
      "key": "base_url",
      "value": "http://127.0.0.1:8000"
    },
    {
      "key": "query",
      "value": "iPhone 15"
    }
  ]
}
