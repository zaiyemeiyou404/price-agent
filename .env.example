# 大模型配置
LLM_PROVIDER=glm5  # glm5 / gpt4o / deepseek
GLM5_API_KEY=your_glm5_key
GLM5_BASE_URL=https://open.bigmodel.cn/api/paas/v4
OPENAI_API_KEY=your_openai_key
DEEPSEEK_API_KEY=your_deepseek_key

# Redis缓存
REDIS_URL=redis://localhost:6379/0

# 爬虫配置
CRAWLER_TIMEOUT=30
CRAWLER_DELAY=2  # 请求间隔(秒)
CRAWLER_PROXY=   # 代理地址 (可选)

# 淘宝登录Cookie (手动登录后获取)
TAOBAO_COOKIE=

# 美团定位
MEITUAN_LAT=39.9042
MEITUAN_LNG=116.4074

# 运行模式
# 强制纯爬虫模式（即使在 .env 中设置 API_MODE 也会被忽略）
API_MODE=false
